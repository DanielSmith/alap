{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "alap/storage": ["../../src/storage/index.ts"],
      "alap/core": ["../../src/core/index.ts"],
      "alap": ["../../src/index.ts"]
    }
  },
  "include": ["src", "../shared"]
}
