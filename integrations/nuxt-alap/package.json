{
  "name": "nuxt-alap",
  "version": "0.1.0",
  "description": "Nuxt integration for Alap — auto-register components, config helpers for Nuxt 3",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "vue",
    "alap",
    "links",
    "menus",
    "web-component"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "alap": "^3.0.0",
    "nuxt": "^3.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "alap": "workspace:*",
    "nuxt": "^3.17.0",
    "vue": "^3.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "author": "Daniel Smith"
}
