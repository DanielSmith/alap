---
/**
 * <AlapLink> — Astro component for Alap menus.
 *
 * Renders an `<alap-link>` web component with typed props.
 * The web component hydrates client-side to handle clicks,
 * keyboard navigation, and menu dismissal.
 *
 * Requires AlapSetup to be included once (in <head> or layout)
 * to register the config and define the custom element.
 *
 * @example
 * <AlapLink query=".coffee">Favorite cafes</AlapLink>
 * <AlapLink query=".nyc + .bridge" id="nyc_bridges">NYC Bridges</AlapLink>
 */

interface Props {
  /** Alap expression (e.g. ".coffee", "item1, item2", ".nyc + .bridge") */
  query: string;
  /** Element ID — also used for @macro self-reference */
  id?: string;
  /** Named config to use (default: '_default') */
  config?: string;
  /** Additional CSS class on the trigger */
  class?: string;
  /** Any other HTML attributes */
  [key: string]: unknown;
}

const { query, id, config, class: className, ...rest } = Astro.props;
---

<alap-link
  query={query}
  id={id}
  config={config}
  class={className}
  {...rest}
>
  <slot />
</alap-link>
