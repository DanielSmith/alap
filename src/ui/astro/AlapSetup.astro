---
/**
 * <AlapSetup> — Include once per page (typically in your layout's <head>).
 *
 * Registers the Alap config and defines the <alap-link> custom element.
 * Must run before any <AlapLink> components on the page.
 *
 * @example
 * ---
 * import { AlapSetup } from 'alap/astro';
 * import myConfig from '../data/alap-config.json';
 * ---
 * <html>
 *   <head>
 *     <AlapSetup config={myConfig} />
 *   </head>
 *   <body>...</body>
 * </html>
 *
 * For multiple named configs:
 * <AlapSetup config={primaryConfig} name="primary" />
 * <AlapSetup config={secondaryConfig} name="secondary" />
 */

import type { AlapConfig } from '../../core/types';

interface Props {
  /** The Alap config object */
  config: AlapConfig;
  /** Config name (default: '_default') */
  name?: string;
}

const { config, name = '_default' } = Astro.props;
const configJson = JSON.stringify(config);
---

<alap-setup
  data-config={configJson}
  data-name={name}
  style="display:none"
></alap-setup>

<script>
  import { registerConfig, defineAlapLink } from 'alap';

  defineAlapLink();

  document.querySelectorAll('alap-setup').forEach((el) => {
    const config = JSON.parse(el.getAttribute('data-config')!);
    const name = el.getAttribute('data-name') || '_default';
    registerConfig(config, name);
  });
</script>
