{
  "name": "alap",
  "version": "3.0.0-beta.1",
  "description": "Dynamic menus for links — one click, multiple destinations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/ui/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./vue": {
      "types": "./dist/ui/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./svelte": {
      "types": "./dist/ui/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "import": "./dist/svelte/index.js",
      "require": "./dist/svelte/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./astro": {
      "types": "./dist/ui/astro/index.d.ts",
      "import": "./dist/astro/index.js",
      "require": "./dist/astro/index.cjs"
    },
    "./astro/AlapLink.astro": "./src/ui/astro/AlapLink.astro",
    "./astro/AlapSetup.astro": "./src/ui/astro/AlapSetup.astro",
    "./alpine": {
      "types": "./dist/ui/alpine/index.d.ts",
      "import": "./dist/alpine/index.js",
      "require": "./dist/alpine/index.cjs"
    },
    "./solid": {
      "types": "./dist/ui/solid/index.d.ts",
      "import": "./dist/solid/index.js",
      "require": "./dist/solid/index.cjs"
    }
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0",
    "astro": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "idb": "^8.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "solid-js": "^1.8.0",
    "svelte": "^5.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "idb": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "alpinejs": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src/ui/astro/*.astro"
  ],
  "scripts": {
    "dev": "vite serve examples",
    "build": "vite build && vite build --config vite.config.iife.ts && tsc --emitDeclarationOnly --outDir dist && tsc -p tsconfig.solid.json --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "links",
    "menu",
    "navigation",
    "multi-link",
    "contextual",
    "web-component",
    "typescript",
    "dropdown",
    "shadow-dom"
  ],
  "author": "Daniel Smith",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielSmith/alap.git"
  },
  "homepage": "https://github.com/DanielSmith/alap#readme",
  "bugs": {
    "url": "https://github.com/DanielSmith/alap/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "picomatch": ">=4.0.4"
    }
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.3",
    "idb": "^8.0.3",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "solid-js": "^1.9.11",
    "svelte": "^5.53.11",
    "typescript": "^5.7.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^3.0.0",
    "vue": "^3.5.30"
  }
}
