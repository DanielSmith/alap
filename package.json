{
  "name": "alap",
  "version": "3.2.0",
  "description": "Dynamic menus for links — one click, multiple destinations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./slim": {
      "types": "./dist/slim.d.ts",
      "import": "./dist/slim.js",
      "require": "./dist/slim.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/ui/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./vue": {
      "types": "./dist/ui/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./svelte": {
      "types": "./dist/ui/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "import": "./dist/svelte/index.js",
      "require": "./dist/svelte/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./protocols/obsidian": {
      "types": "./dist/protocols/obsidian/index.d.ts",
      "import": "./dist/protocols/obsidian/index.js",
      "require": "./dist/protocols/obsidian/index.cjs"
    },
    "./astro": {
      "types": "./dist/ui/astro/index.d.ts",
      "import": "./dist/astro/index.js",
      "require": "./dist/astro/index.cjs"
    },
    "./astro/AlapLink.astro": "./src/ui/astro/AlapLink.astro",
    "./astro/AlapSetup.astro": "./src/ui/astro/AlapSetup.astro",
    "./alpine": {
      "types": "./dist/ui/alpine/index.d.ts",
      "import": "./dist/alpine/index.js",
      "require": "./dist/alpine/index.cjs"
    },
    "./solid": {
      "types": "./dist/ui/solid/index.d.ts",
      "import": "./dist/solid/index.js",
      "require": "./dist/solid/index.cjs"
    },
    "./qwik": {
      "types": "./dist/ui/qwik/index.d.ts",
      "import": "./dist/qwik/index.js",
      "require": "./dist/qwik/index.cjs"
    },
    "./lightbox.css": "./dist/lightbox.css",
    "./lens.css": "./dist/lens.css",
    "./embed.css": "./dist/embed.css",
    "./transitions.css": "./dist/rendererTransitions.css"
  },
  "peerDependencies": {
    "@builder.io/qwik": "^1.19.0",
    "alpinejs": "^3.0.0",
    "astro": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "idb": "^8.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "solid-js": "^1.8.0",
    "svelte": "^5.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "idb": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "alpinejs": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "@builder.io/qwik": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src/ui/astro/*.astro"
  ],
  "scripts": {
    "dev": "vite serve examples/sites --config vite.config.ts",
    "build": "vite build && vite build --config vite.config.iife.ts && cp src/ui-lightbox/lightbox.css src/ui-lens/lens.css src/ui-embed/embed.css src/ui/shared/rendererTransitions.css dist/ && tsc --emitDeclarationOnly --outDir dist && tsc -p tsconfig.solid.json --emitDeclarationOnly --outDir dist && tsc -p tsconfig.qwik.json --emitDeclarationOnly --outDir dist",
    "build:lib": "vite build && vite build --config vite.config.iife.ts && cp src/ui-lightbox/lightbox.css src/ui-lens/lens.css src/ui-embed/embed.css src/ui/shared/rendererTransitions.css dist/",
    "copy:iife": "cp dist/alap.iife.js examples/sites/cdn/ && cp dist/alap.iife.js examples/sites/htmx/",
    "build:all": "pnpm turbo run build --continue",
    "test": "vitest run",
    "test:all": "turbo run test",
    "test:watch": "vitest",
    "test:scripts": "python3 -m pytest scripts/tests/",
    "vault:docs": "python3 scripts/vault_docs.py",
    "vault:demo": "python3 scripts/vault_demo.py",
    "vault:convert": "python3 scripts/vault_convert.py",
    "feed:to-md": "python3 scripts/feed_to_md.py",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "turbo run typecheck",
    "clean": "rm -rf dist dist-tgz .turbo tsconfig.tsbuildinfo",
    "clean:all": "pnpm -r exec rm -rf dist .turbo && rm -rf dist-tgz tsconfig.tsbuildinfo",
    "pack:lib": "pnpm run build:lib && pnpm pack --pack-destination ./dist-tgz",
    "test:packaging": "vitest run --config vitest.packaging.ts",
    "docker:express": "pnpm run pack:lib && podman build -t alap-express -f examples/servers/express-sqlite/Dockerfile .",
    "docker:bun": "pnpm run pack:lib && podman build -t alap-bun -f examples/servers/bun-sqlite/Dockerfile .",
    "docker:hono": "pnpm run pack:lib && podman build -t alap-hono -f examples/servers/hono-sqlite/Dockerfile .",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "links",
    "menu",
    "navigation",
    "multi-link",
    "contextual",
    "web-component",
    "typescript",
    "dropdown",
    "shadow-dom"
  ],
  "author": "Daniel Smith",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielSmith/alap.git"
  },
  "homepage": "https://github.com/DanielSmith/alap#readme",
  "bugs": {
    "url": "https://github.com/DanielSmith/alap/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5",
      "lodash": ">=4.18.0",
      "esbuild": ">=0.25.0",
      "defu": ">=6.1.5",
      "vite": ">=6.4.2 <7.0.0",
      "liquidjs": ">=10.25.7"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@mdx-js/rollup": "^3.1.1",
    "@solidjs/testing-library": "^0.8.10",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.8",
    "idb": "^8.0.3",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-parse": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "solid-js": "^1.9.11",
    "svelte": "^5.53.11",
    "turbo": "^2.9.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^3.0.0",
    "vue": "^3.5.30"
  },
  "dependencies": {
    "undici": "^7.24.6"
  }
}
